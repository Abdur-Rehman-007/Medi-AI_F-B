{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Medi-AI Frontend (Web - Chrome)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "chrome"
        },
        {
            "name": "Medi-AI Frontend (Windows Desktop)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "windows"
        },
        {
            "name": "Medi-AI Frontend (Mobile)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug"
        },
        {
            "name": "Medi-AI Frontend (Release Mode - No Debug)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "Medi-AI Backend (API)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Backend/Medi-AI_backend-main/Backend-APIs/bin/Debug/net8.0/Backend-APIs.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Backend/Medi-AI_backend-main/Backend-APIs",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ],
    "compounds": [
        {
            "name": "Full Stack (Web - Chrome)",
            "configurations": ["Medi-AI Backend (API)", "Medi-AI Frontend (Web - Chrome)"],
            "stopAll": true
        },
        {
            "name": "Full Stack (Windows Desktop)",
            "configurations": ["Medi-AI Backend (API)", "Medi-AI Frontend (Windows Desktop)"],
            "stopAll": true
        },
        {
            "name": "Full Stack (Mobile + Backend)",
            "configurations": ["Medi-AI Backend (API)", "Medi-AI Frontend (Mobile)"],
            "stopAll": true
        }
    ]
}